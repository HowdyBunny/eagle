# Database
DATABASE_URL=postgresql+asyncpg://eagle:eagle@localhost:5432/eagle

# Anthropic (LLM for all Agents: CA, RA, EA)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_BASE_URL=https://your-proxy.example.com  # Uncomment to use a compatible API or proxy

# OpenAI (Embedding only: text-embedding-3-small)
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
# OPENAI_BASE_URL=https://your-azure-endpoint.openai.azure.com/  # Uncomment for Azure / local proxy

# Authentication (X-API-Key header)
API_KEY=your-secret-api-key-here

# App settings
LOG_LEVEL=INFO

# Eagle file storage root (Mac/Linux default: ~/Desktop/Eagle)
# Windows: set to C:/Users/<you>/Desktop/Eagle or use forward slashes
# EAGLE_BASE_DIR=~/Desktop/Eagle
