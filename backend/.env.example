# Database
# DATABASE_URL

# ── Core LLM (CA / RA / EA) ──────────────────────────────────────────────────
# LLM_PROVIDER controls which SDK is used. Default: openai
#   openai    → OpenAI SDK (chat.completions + responses API)
#   anthropic → Anthropic SDK (messages API)
LLM_PROVIDER=openai
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o

# Base URL for third-party / proxy providers:
#   LLM_PROVIDER=openai    → must include /v1  (e.g. https://geekai.co/api/v1)
#   LLM_PROVIDER=anthropic → must NOT include /v1 (e.g. https://your-proxy.com)
# LLM_BASE_URL=https://your-provider.example.com/v1

# Web search context size used by RA (openai Responses API only)
# WEB_SEARCH_CONTEXT_SIZE=low   # low | medium | high

# ── Embedding ─────────────────────────────────────────────────────────────────
# Any OpenAI-compatible embedding endpoint; LLM_BASE_URL rules apply (must include /v1)
EMBEDDING_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
# EMBEDDING_BASE_URL=https://your-provider.example.com/v1

# ── Authentication ─────────────────────────────────────────────────────────────
API_KEY=your-secret-api-key-here

# ── App settings ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# Eagle file storage root (Mac/Linux default: ~/Desktop/Eagle)
# Windows: set to C:/Users/<you>/Desktop/Eagle or use forward slashes
# EAGLE_BASE_DIR=~/Desktop/Eagle
