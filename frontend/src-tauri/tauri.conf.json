{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Eagle",
  "version": "0.1.1",
  "identifier": "com.howdybunny.eagle",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build && rm -rf src-tauri/binaries && mkdir -p src-tauri/binaries && cp -R ../backend/dist/eagle-backend src-tauri/binaries/backend"
  },
  "app": {
    "windows": [
      {
        "title": "Eagle",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "binaries/backend/**/*"
    ]
  }
}
